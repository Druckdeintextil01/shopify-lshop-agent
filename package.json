const Anthropic = require('@anthropic-ai/sdk');
const products = require('./config/products.json');

const client = new Anthropic({ apiKey: process.env.ANTHROPIC_API_KEY });

/**
 * Nutzt Claude KI um Shopify Bestellpositionen auf L-Shop Artikel zu mappen.
 * @param {Array} lineItems - Shopify Bestellpositionen
 * @returns {Array} - Gemappte L-Shop Artikel mit Artikelnummer, Farbe, Größe, Menge
 */
async function mapProductsToLShop(lineItems) {
  const mappedItems = [];

  for (const item of lineItems) {
    // 1. Versuche zuerst direktes Mapping aus config/products.json
    const directMatch = tryDirectMapping(item);
    if (directMatch) {
      mappedItems.push(directMatch);
      continue;
    }

    // 2. Fallback: Claude KI mappt das Produkt
    const aiMatch = await mapWithAI(item);
    if (aiMatch) {
      mappedItems.push(aiMatch);
    } else {
      console.error(`⚠️  Konnte Artikel nicht mappen: ${item.title} - ${item.variant_title}`);
      mappedItems.push({
        shopify_title: item.title,
        error: 'Kein passendes L-Shop Produkt gefunden',
        quantity: item.quantity
      });
    }
  }

  return mappedItems;
}

function tryDirectMapping(item) {
  const title = (item.title || '').toLowerCase();
  const variant = (item.variant_title || '').toLowerCase();

  for (const product of products.produkte) {
    const keywords = product.shopify_keywords || [];
    const matches = keywords.some(kw => title.includes(kw));

    if (!matches) continue;

    // Farbe aus Variant-Titel extrahieren
    const farbe = extractColor(variant, product.farben_mapping);
    // Größe aus Variant-Titel extrahieren
    const groesse = extractSize(variant);

    return {
      shopify_title: item.title,
      lshop_artikel: product.lshop_artikel,
      lshop_name: product.lshop_name,
      farbe_lshop: farbe,
      groesse: groesse,
      quantity: item.quantity,
      mapped_by: 'config'
    };
  }

  return null;
}

async function mapWithAI(item) {
  const productList = products.produkte.map(p =>
    `- Artikelnummer: ${p.lshop_artikel}, Name: ${p.lshop_name}, Keywords: ${p.shopify_keywords.join(', ')}`
  ).join('\n');

  const prompt = `Du bist ein Assistent für ein Textildruck-Unternehmen.
Ordne den folgenden Shopify-Artikel dem passenden L-Shop Artikel zu.

Shopify Artikel:
- Produktname: ${item.title}
- Variante: ${item.variant_title || 'keine'}
- SKU: ${item.sku || 'keine'}
- Menge: ${item.quantity}

Verfügbare L-Shop Artikel:
${productList}

Antworte NUR mit einem JSON-Objekt (kein Markdown, kein Text davor/danach):
{
  "lshop_artikel": "Artikelnummer aus der Liste",
  "farbe_lshop": "Farbe auf Englisch wie bei L-Shop üblich",
  "groesse": "Größe z.B. S, M, L, XL, XXL",
  "confidence": "high|medium|low"
}

Wenn kein passender Artikel gefunden wurde, antworte mit: {"error": "nicht gefunden"}`;

  try {
    const response = await client.messages.create({
      model: 'claude-sonnet-4-20250514',
      max_tokens: 300,
      messages: [{ role: 'user', content: prompt }]
    });

    const text = response.content[0].text.trim();
    const result = JSON.parse(text);

    if (result.error) return null;

    return {
      shopify_title: item.title,
      ...result,
      quantity: item.quantity,
      mapped_by: 'ai'
    };
  } catch (err) {
    console.error('Claude API Fehler:', err.message);
    return null;
  }
}

function extractColor(variantText, colorMap) {
  const text = variantText.toLowerCase();
  for (const [de, en] of Object.entries(colorMap || {})) {
    if (text.includes(de.toLowerCase())) return en;
  }
  // Fallback: Erste Variante als Farbe nehmen
  return variantText.split('/')[0]?.trim() || 'White';
}

function extractSize(variantText) {
  const sizePattern = /\b(XS|S|M|L|XL|XXL|3XL|4XL|5XL|\d{2,3})\b/i;
  const match = variantText.match(sizePattern);
  return match ? match[1].toUpperCase() : 'M';
}

module.exports = { mapProductsToLShop };
